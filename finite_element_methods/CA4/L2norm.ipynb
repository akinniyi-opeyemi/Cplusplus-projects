import os
import numpy as np
import matplotlib.pyplot as plt
import vtk
from vtk.util.numpy_support import vtk_to_numpy, numpy_to_vtk


def getPathInfo(savePath,dt):

    dtVal = float(dt.replace('_','.'))
    filePath = os.path.join(savePath,"dt"+dt)
    filename = f"solution_{timeIdx}.vtk"

    # Error chacking. Exits if directories or solution files are not found
    if os.path.exists(filePath) == False:
        print(f'No data found for time step, dt = {dt}\n   ...exiting\n')
        exit()
    if os.path.exists(os.path.join(filePath,filename)) == False:
        print(f'Directory exists, but no vtk file found for tIdx = {timeIdx}\nPlease select a valid index\n   ...exiting\n')
        exit()

    return dtVal,filePath,filename

def getSimData(path):
    reader = vtk.vtkUnstructuredGridReader()
    reader.SetFileName(path)
    reader.ReadAllVectorsOn()
    reader.ReadAllScalarsOn()
    reader.Update()

    grid = reader.GetOutput()
    sol = vtk_to_numpy(grid.GetPointData().GetArray("D"))
    pts = vtk_to_numpy(grid.GetPoints().GetData())

    return sol, pts


################################## Set up parameters for the script ##################################
alpha = "0_0"                       # EDIT: Select time-stepping scheme for comparison (Note: this script only compares within a single time stepping scheme, not between them)
referenceDT = "0_2"                 # EDIT: Select time step to use as the "exact" solution (i.e. "0_1")
compareDT = ["2_0", "1_0","0_4"]    # EDIT: List of time steps to compare. List in decreasing order -- important if you change mesh size (i.e. ["10_0","2_0","1_0"])
timeIdx = 1000                      # EDIT: This is the time step at which the norm will be evaluated (i.e. 100, 200, 1000, etc.)
PLOT_STEADY_NORM = False            # EDIT: This will create a plot of the steady L2 norms for each time step compared for this scheme (Note: this does not help you compare across time-stepping schemes)

if PLOT_STEADY_NORM:
    figSY,axSY = plt.subplots()

################################## Get reference time step ##################################
savePath = "Alpha"+alpha
if os.path.exists(savePath) == False:
    print(f'No data found for scheme, alpha = {alpha}\n   ...exiting\n')
    exit()

dtExact, filePath, filename = getPathInfo(savePath,referenceDT)
u_exact, pt_exact = getSimData(os.path.join(filePath,filename))

if PLOT_STEADY_NORM:
    steadyL2Data = np.loadtxt(os.path.join(filePath,"L2norm.csv"), delimiter=",", dtype=str)[1:,:].astype(float)
    plt.plot(steadyL2Data[:,0],steadyL2Data[:,1],label=referenceDT.replace('_','.'))


################################## Get all other time step data ##################################
dtPlot          = np.zeros((len(compareDT)))
exactL2Norm     = np.zeros((len(compareDT)))
exactPtIdxs = []
for dtIdx,dt in enumerate(compareDT):
    
    dtVal, filePath, filename = getPathInfo(savePath,dt)
    u,ptData = getSimData(os.path.join(filePath,filename))

    # Points used for comparison should be based on the largest mesh
    if dtIdx == 0:
        refPts = ptData
        # Get the exact solution at the reference points
        count = 0
        for pt in refPts:
            idx = np.where((pt_exact == pt).all(axis=1))
            if idx != []:
                exactPtIdxs.append(idx[0][0])
    # Smaller meshes should have points that lie on the larger mesh
    else:
        ptIdxs = []
        count = 0
        for pt in refPts:
            idx = np.where((ptData == pt).all(axis=1))
            if idx != []:
                ptIdxs.append(idx[0][0])
        u = u[ptIdxs]
    
    if u.shape != u_exact[exactPtIdxs].shape:
        print("Solution sizes do not match! Potential sub-sampling error")
        exit()
    
    # Save the L2 norm compared to the "exact" solution
    dtPlot[dtIdx] = dtVal
    exactL2Norm[dtIdx] = np.sqrt(np.sum((u-u_exact[exactPtIdxs])**2))

    if PLOT_STEADY_NORM:
        steadyL2Data = np.loadtxt(os.path.join(filePath,"L2norm.csv"), delimiter=",", dtype=str)[1:,:].astype(float)
        plt.plot(steadyL2Data[:,0],steadyL2Data[:,1],label=dtVal)

if PLOT_STEADY_NORM:
    plt.legend(title="$\Delta t$")
    axSY.set_ylabel("$||u_{steady}-u_{t_n}||_2$")
    axSY.set_xlabel("t [s]",)
    plt.savefig(os.path.join(savePath,'SteadyL2Norms.png'))
    plt.close()

################################## Print the L2 norms to the terminal ##################################
print(f'Comparing {len(compareDT)} solutions at time {timeIdx} s.')
print(f"Using dt = {dtExact} as the 'exact' solution.")
print('         dt       |        L2          ')
print('---------------------------------------')
for dtIdx,dtVal in enumerate(dtPlot):
    print(f"     {dtVal:1.2e}     |     {exactL2Norm[dtIdx]:1.3e}")

################################## Plot the L2 norms on a log-log plot ##################################
fig,ax = plt.subplots(figsize=(8,5))
dtPlot = 1/dtPlot
# Plot the L2 norm compared to "exact" solution
plt.plot(dtPlot,exactL2Norm,label='$||u_{\Delta t}-u_{refined}||_2$')

# Plot the expected order of convergence, this will add a line to the plot so you can compare slopes
scalingIdx = -1     # EDIT: This will shift the "expected" order line up or down based on the index selected (-1 = end, 0 = beginning)
expectedOrder = 1   # EDIT: Expected order of convergence, (1, 2, 3, etc.)
yShift = exactL2Norm[scalingIdx]/(dtPlot[scalingIdx]**(-expectedOrder))
plt.plot(dtPlot,(dtPlot**(-expectedOrder))*yShift,'--',label=f'Order {expectedOrder}')

# Figure axis and title labels, show as log-log, and save
ax.set_ylabel("Error")
ax.set_xlabel("$1/\Delta t$",)
plt.title(f"L2 norm for t={timeIdx} s")
plt.rcParams['text.usetex'] = True
plt.xscale("log") 
plt.yscale("log")
plt.legend()
plt.savefig(os.path.join(savePath,'ExactL2Norms.png'))
plt.close()